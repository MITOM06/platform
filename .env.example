# connector-service (:3003) environment template — copy to .env and fill in.

PORT=3003
MONGO_URI=mongodb://localhost:27018/platform

# AES-256-GCM token vault key — MUST base64-decode to exactly 32 bytes.
# Generate: openssl rand -base64 32
CONNECTOR_VAULT_KEY=

# Shared secret for the internal tools API (ai-service <-> connector-service)
# and OAuth state HMAC. Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# Must match auth-service JWT_ACCESS_SECRET exactly.
JWT_ACCESS_SECRET=

# OAuth redirect plumbing.
OAUTH_REDIRECT_BASE=http://localhost:3003
CLIENT_REDIRECT_URL=http://localhost:3000/integrations

# -- Notion connector (remote MCP) --
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_MCP_URL=https://mcp.notion.com/sse

# -- Google connectors: Gmail + Calendar (REST adapter, P5) --
# One OAuth app for both. Enable Gmail API + Calendar API in Google Cloud,
# create an OAuth 2.0 client, and set the redirect URI to
#   ${OAUTH_REDIRECT_BASE}/oauth/gmail/callback  and  .../oauth/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
