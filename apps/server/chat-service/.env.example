# chat-service env (sao chép thành .env). File .env bị gitignore.

# JWT — PHẢI trùng JWT_ACCESS_SECRET của auth-service.
JWT_ACCESS_SECRET=change_me_same_as_auth_service

# Bot Factory bridge — URL của Bot Factory service và worker token dùng chung.
# Để TRỐNG ⇒ bridge tắt (no-op an toàn).
BOTFACTORY_BASE_URL=
BOTFACTORY_WORKER_TOKEN=

# Firebase Admin SDK cho push (FCM). Base64 của file service-account JSON:
#   base64 -i pon-xxxx-firebase-adminsdk-xxxx.json | tr -d '\n'
# Để TRỐNG ⇒ FCM tắt (no-op an toàn, không ảnh hưởng gửi tin).
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Comma-separated CORS allow-list. REQUIRED (no wildcard default) — service refuses to start if unset.
ALLOWED_ORIGINS=http://localhost:3000
