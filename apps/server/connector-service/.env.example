# connector-service — :3003
PORT=3003

# MongoDB (shared `platform` db, non-standard port 27018)
MONGO_URI=mongodb://localhost:27018/platform

# AES-256-GCM token vault key. MUST base64-decode to exactly 32 bytes.
# Generate one with: openssl rand -base64 32
# Service refuses to boot if this is not 32 bytes.
CONNECTOR_VAULT_KEY=

# Shared secret guarding the internal ai-service <-> connector-service API
# (sent as the `x-internal-key` header). Must match ai-service INTERNAL_API_KEY.
INTERNAL_API_KEY=

# JWT validation — must be IDENTICAL across all services.
JWT_ACCESS_SECRET=

# OAuth redirect base (this service's public origin) + client deep-link back target.
OAUTH_REDIRECT_BASE=http://localhost:3003
CLIENT_REDIRECT_URL=http://localhost:3000/integrations

# Notion connector (remote MCP, OAuth)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_MCP_URL=https://mcp.notion.com/sse
