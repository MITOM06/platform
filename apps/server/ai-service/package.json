{
  "name": "@platform/ai-service",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "eval": "ts-node --transpile-only eval/run-eval.ts",
    "eval:gate": "EVAL_MIN_PASS_RATE=${EVAL_MIN_PASS_RATE:-0.8} ts-node --transpile-only eval/run-eval.ts",
    "eval:import-feedback": "ts-node --transpile-only eval/import-feedback.ts",
    "gen:openapi": "ts-node --transpile-only src/generate-openapi.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@golevelup/nestjs-rabbitmq": "^5.6.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@platform/database": "workspace:*",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "@sentry/node": "^10.57.0",
    "amqplib": "^0.10.7",
    "helmet": "^8.2.0",
    "ioredis": "^5.8.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.19.2",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "ioredis-mock": "^8.9.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@platform/database$": "<rootDir>/../../../../packages/database/src"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
