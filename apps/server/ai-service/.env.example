PORT=3002
JWT_ACCESS_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb://localhost:27018/platform
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic models — bare model ids, NO date suffix.
# Primary: claude-opus-4-8 (strongest). Cheaper alternative: claude-sonnet-4-6.
# Fallback (on overload/529): claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5
# output_config effort for the agentic loop: low | medium | high
ANTHROPIC_EFFORT=high
# Adaptive thinking on the primary model (Opus 4.8 / Sonnet 4.6 use adaptive thinking, not budget_tokens).
AI_ENABLE_THINKING=false

# ── Complexity-based 3-tier model routing ──────────────────────────────────
# Routes simple turns to cheaper models to cut cost. Enabled by default.
# Set to "false" (literal string) to disable and always use complexModel.
ANTHROPIC_ROUTER_ENABLED=true

# Model IDs for each tier (bare ids, no date suffix):
#   Haiku 4.5  → $1/$5 per MTok   — simple turns (short, no KB)
#   Sonnet 4.6 → $3/$15 per MTok  — medium turns
#   Opus 4.8   → $5/$25 per MTok  — complex turns + KB-grounded answers
ANTHROPIC_SIMPLE_MODEL=claude-haiku-4-5
ANTHROPIC_MID_MODEL=claude-sonnet-4-6
ANTHROPIC_COMPLEX_MODEL=claude-opus-4-8

# Thresholds for tier selection:
#   simple tier: content <= SIMPLE_MAX_CHARS AND history <= SIMPLE_MAX_HISTORY turns AND no KB
#   mid tier:    content <= MID_MAX_CHARS AND history <= MID_MAX_HISTORY turns AND no KB
#   otherwise:   complex tier (Opus)
ANTHROPIC_ROUTER_SIMPLE_MAX_CHARS=280
ANTHROPIC_ROUTER_SIMPLE_MAX_HISTORY=4
ANTHROPIC_ROUTER_MID_MAX_CHARS=1200
ANTHROPIC_ROUTER_MID_MAX_HISTORY=20

AI_BOT_USER_ID=ai-bot-000000000000000000000001
AI_BOT_DISPLAY_NAME=PON AI
REDIS_AI_REQUEST_CHANNEL=ai:request
REDIS_AI_RESPONSE_PREFIX=ai:response
RABBITMQ_URL=amqp://platform:platform@localhost:5672
# Embeddings for RAG / memory / semantic cache — Voyage AI (Anthropic's
# recommended embeddings partner). Unset = RAG & long-term memory disabled.
VOYAGE_API_KEY=
KB_EMBEDDING_MODEL=voyage-3.5
QDRANT_URL=http://localhost:6333

# Knowledge-base RAG tuning
QDRANT_KB_COLLECTION=knowledge
KB_TOP_K=4
KB_OVERFETCH=8
KB_SCORE_THRESHOLD=0.5

# Semantic memory (embedding-backed fact store)
QDRANT_MEMORY_COLLECTION=ai_memory
MEMORY_TOP_FACTS=6
MEMORY_DEDUP_THRESHOLD=0.92
MEMORY_EXTRACT_EVERY=20
MEMORY_HALFLIFE_DAYS=30

# Monthly per-user token budget
AI_MONTHLY_TOKEN_LIMIT=500000

# ── OpenTelemetry tracing ──────────────────────────────────────────────────────
# Set to "false" to disable all OTel instrumentation (default: enabled).
OTEL_ENABLED=true
# OTLP HTTP collector endpoint (Jaeger all-in-one or any OTLP-compatible backend).
# Defaults to http://localhost:4318 when unset.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Print spans to stdout in addition to (or instead of) OTLP export.
# Useful for local debugging without Jaeger running.
OTEL_TRACES_CONSOLE=false
# Service name reported to the collector (default: ai-service).
OTEL_SERVICE_NAME=ai-service

# ── Web search tool (TASK-09) ──────────────────────────────────────────────────
# Built-in `web_search` tool. ON by default; set to "false" to never register it.
WEB_SEARCH_ENABLED=true
# Provider: "generic" = generic search API (Brave/Tavily-style) via the URL+key
# below; "anthropic" = Anthropic server-side web search (currently a no-op stub).
WEB_SEARCH_PROVIDER=generic
# Generic provider config. WITHOUT a key the tool degrades gracefully (not
# registered). Do NOT commit a real key.
WEB_SEARCH_API_URL=
WEB_SEARCH_API_KEY=
# Default max results per search (1–10).
WEB_SEARCH_MAX_RESULTS=5

# ── Usage & cost dashboard pricing (TASK-13) ───────────────────────────────────
# Per-model token prices (USD per 1M tokens) for the admin usage dashboard
# (GET /usage/dashboard). Ops/billing constants — change rarely. A model seen in
# messages.trace but with no override here uses the AI_PRICE_DEFAULT_* values.
# Env key = model id upper-cased, non-alphanumerics → '_'
#   e.g. claude-opus-4-8 → AI_PRICE_CLAUDE_OPUS_4_8_IN / _OUT
# Seeded defaults (already baked in, override only if your contract differs):
#   claude-haiku-4-5  = 1 / 5
#   claude-sonnet-4-6 = 3 / 15
#   claude-opus-4-8   = 15 / 75
# AI_PRICE_CLAUDE_OPUS_4_8_IN=15
# AI_PRICE_CLAUDE_OPUS_4_8_OUT=75
# Fallback prices for any model NOT in the seeded map above.
AI_PRICE_DEFAULT_IN=3
AI_PRICE_DEFAULT_OUT=15

# ── TASK-10 Vision / image understanding ───────────────────────────────────
# KB half: image uploads + scanned/sparse PDFs are described via Claude vision
# and the description is indexed. Master switch (default on); degrades gracefully
# (no key / disabled / vision error / unsupported mime ⇒ prior behavior).
KB_VISION_ENABLED=true
KB_VISION_PDF_ENABLED=true
# Below this many extracted chars, a PDF is treated as scanned and routed to vision.
KB_VISION_MIN_TEXT_CHARS=64
# Per-image/PDF base64 size cap (~5MB Anthropic limit).
KB_VISION_MAX_IMAGE_BYTES=5000000
# Chat half: image attachments in @AI history → image content blocks (server-fetched).
CHAT_VISION_ENABLED=true
CHAT_VISION_MAX_IMAGES=4
CHAT_VISION_MAX_IMAGE_BYTES=5000000
# chat-service base used to resolve RELATIVE /api/uploads/{id} refs in history.
CHAT_INTERNAL_URL=http://localhost:8080
