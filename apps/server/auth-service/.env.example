# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MONGO_URI is used by the config layer (mongo.config.ts / process.env.MONGO_URI).
# MONGODB_URI is kept for library/ORM compatibility. Set both to the same value.
MONGO_URI=mongodb://localhost:27018/platform
MONGODB_URI=mongodb://localhost:27018/platform

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be identical across auth-service, chat-service, and ai-service.
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=30d

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=your_session_secret_here
# TTL in seconds for refresh tokens stored in Redis (default 30 days = 2592000)
REFRESH_TOKEN_TTL_SECONDS=2592000
# Set to "true" to revoke ALL sessions for a user when refresh-token reuse is detected
REFRESH_REUSE_REVOKE_ALL=false

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_password

# ── OTP / Brute-force protection ─────────────────────────────────────────────
# Number of allowed OTP verification attempts before lockout
MAX_OTP_ATTEMPTS=5
# TTL in seconds for the OTP attempt counter
OTP_ATTEMPTS_TTL=300
# Cooldown in seconds before a user can request a new OTP
OTP_RESEND_COOLDOWN=60
# Maximum failed login attempts before account lockout
MAX_FAILED_ATTEMPTS=5
# Window in seconds during which failed login attempts are counted
FAILED_LOGIN_ATTEMPTS_TTL=600
# Duration in seconds an account stays locked after too many failures
LOCKOUT_DURATION=300

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank for defaults)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Deep-links (Social OAuth redirect) ───────────────────────────────────────
# URL the web client should be redirected to after social login
WEB_REDIRECT_URL=http://localhost:8081
# Optional: mobile deep-link base URL used for custom deep-link schemes
MOBILE_DEEPLINK_URL=platform://auth

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ── X (Twitter) OAuth ────────────────────────────────────────────────────────
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_CALLBACK_URL=http://localhost:3001/auth/x/callback

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable Sentry error reporting
SENTRY_DSN=
