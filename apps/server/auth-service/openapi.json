  "info": {
    "title": "Platform Auth Service",
    "description": "Authentication, OTP, refresh tokens, user search and friends API.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": "Login, registration, OTP and token endpoints"
    },
    {
      "name": "users",
      "description": "User profile and search"
    },
    {
      "name": "friends",
      "description": "Friend requests and relationships"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "FriendRequestDto": {
        "type": "object",
        "properties": {
          "recipientId": {
            "type": "string",
            "description": "User id of the friend-request recipient"
          }
        },
        "required": [
          "recipientId"
        ]
      },
      "AcceptFriendDto": {
        "type": "object",
        "properties": {
          "requesterId": {
            "type": "string",
            "description": "User id of the requester whose request is accepted"
          }
        },
        "required": [
          "requesterId"
        ]
      },
      "ExchangeDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "One-time login code returned by the OAuth/login flow"
          },
          "deviceId": {
            "type": "string",
            "description": "Device identifier for the issued session"
          },
          "platform": {
            "type": "string",
            "description": "Originating platform",
            "example": "web"
          }
        },
        "required": [
          "code"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string",
            "description": "Session id issued at login"
          },
          "refreshToken": {
            "type": "string",
            "description": "Opaque refresh token issued at login"
          }
        },
        "required": [
          "sid",
          "refreshToken"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "example": "Jane Doe",
            "description": "Public display name",
            "minLength": 2
          },
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email address (must be unique)"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd123",
            "description": "Account password",
            "minLength": 8
          }
        },
        "required": [
          "displayName",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Registered email address"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd123",
            "description": "Account password",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email to send the reset OTP to"
          }
        },
        "required": [
          "email"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email the OTP was sent to"
          },
          "otp": {
            "type": "string",
            "example": "123456",
            "description": "One-time code from the email"
          }
        },
        "required": [
          "email",
          "otp"
        ]
      },
      "ResendOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email to resend the OTP to"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Email of the account to reset"
          },
          "otp": {
            "type": "string",
            "example": "123456",
            "description": "Verified OTP code"
          },
          "password": {
            "type": "string",
            "example": "N3wP@ssw0rd",
            "description": "New password",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "otp",
          "password"
        ]
      }
    }
  }
}