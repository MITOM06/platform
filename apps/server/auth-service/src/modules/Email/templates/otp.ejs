<div style="font-family: Arial, sans-serif; max-width: 500px; margin: auto; border: 1px solid #eee; padding: 20px;">
  <h2 style="color: #3B71F3; text-align: center;"><%= t.heading %></h2>
  <p><%= t.greeting %></p>
  <p><%= t.instruction %></p>
  <div style="background: #f4f4f4; padding: 15px; text-align: center; font-size: 24px; font-weight: bold; letter-spacing: 5px; color: #3B71F3;">
    <%= otp %>
  </div>
  <p style="font-size: 12px; color: #888; margin-top: 20px;">
    <%= t.expiryNote %>
  </p>
</div>