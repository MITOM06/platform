# connector-service (MCP connectors). Now deployed to Cloud Run — this MUST be
# set or the integrations/skills pages call the web origin's non-existent
# /api/connector fallback (see lib/api/connector.ts + axios.ts) and every skill
# toggle silently fails. Same Cloud Run service as the lwnzrufcxa host used in
# deploy.yml; the connector-service CORS origin (derived from CLIENT_REDIRECT_URL)
# allows this web app regardless of which of the service's URLs we target.
NEXT_PUBLIC_CONNECTOR_URL=https://connector-service-942942821810.asia-southeast1.run.app

NEXT_PUBLIC_AI_URL=https://ai-service-942942821810.asia-southeast1.run.app

