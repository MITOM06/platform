# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample

# Firebase service account (admin SDK) — SECRET, never commit
*firebase-adminsdk*.json
# Firebase client config — generated per-project by `flutterfire configure`
# (firebase_options.dart is committed on purpose: public client config, needed by CI `flutter analyze`)
**/google-services.json
**/GoogleService-Info.plist
# Web push service worker chứa firebaseConfig thật (dùng .example để tái tạo)
apps/client/web/firebase-messaging-sw.js
# flutterfire manifest (metadata app/project id — tái tạo bằng `flutterfire configure`)
apps/client/firebase.json

