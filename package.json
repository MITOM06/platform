{
  "name": "platform",
  "private": true,
  "scripts": {
    "infra": "docker compose -f infra/docker-compose/compose.yml up -d mongo redis",
    "infra:all": "docker compose -f infra/docker-compose/compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose/compose.yml down",
    "down": "docker compose -f infra/docker-compose/compose.yml down",
    "auth": "pnpm --filter @platform/auth-service start:dev",
    "chat": "sh -c 'set -a; . apps/server/chat-service/.env; set +a; mvn -f apps/server/chat-service/pom.xml spring-boot:run'",
    "flutter": "cd apps/client && flutter run",
    "dev": "concurrently -n \"AUTH,CHAT\" -c \"blue,green\" \"pnpm:auth\" \"pnpm:chat\"",
    "web": "pnpm --filter @platform/web dev",
    "tunnel": "pnpm exec ngrok http --url=donnie-readaptable-ai.ngrok-free.dev 4000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "localtunnel": "^2.0.2",
    "ngrok": "5.0.0-beta.2"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1057.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "argon2",
      "bcrypt",
      "ngrok",
      "unrs-resolver",
      "@swc/core",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
